summary_table_2019,
file = "lca_2019_summary.csv",
row.names = FALSE
)
table(lca_descript$class_19_ml)
lca_pcp_merged <- lca_pcp_merged %>%
mutate(
## ---- Race (2009) ----
race_2009 = case_when(
white_2009            == 1 ~ "Non-Hispanic White",
black_2009            == 1 ~ "Non-Hispanic Black",
american_native_2009  == 1 ~ "American Indian/Alaskan Native",
asian_or_pi_2009      == 1 ~ "Asian/Pacific Islander",
hispanicrace_2009     == 1 ~ "Hispanic",
other_race_2009       == 1 ~ "Other",
race_unknown_2009     == 1 ~ "Unknown",
TRUE                       ~ "Missing Value"
),
## ---- Race (2019) ----
race_2019 = case_when(
white_2019            == 1 ~ "Non-Hispanic White",
black_2019            == 1 ~ "Non-Hispanic Black",
american_native_2019  == 1 ~ "American Indian/Alaskan Native",
asian_or_pi_2019      == 1 ~ "Asian/Pacific Islander",
hispanicrace_2019     == 1 ~ "Hispanic",
other_race_2019       == 1 ~ "Other",
race_unknown_2019     == 1 ~ "Unknown",
TRUE                       ~ "Missing Value"
)
)
library(dplyr)
library(tidyr)
library(tibble)
# --- Define full set of race levels (must match how you defined race_2009/2019) ---
race_levels <- c(
"Non-Hispanic White",
"Non-Hispanic Black",
"American Indian/Alaskan Native",
"Asian/Pacific Islander",
"Hispanic",
"Other",
"Unknown",
"Missing Value"
)
# --- Restrict to those observed in both years and lock factor levels ---
lca_pcp_merged_combine <- lca_pcp_merged %>%
filter(in_2009 == 1 & in_2019 == 1) %>%
mutate(
race_2009 = factor(race_2009, levels = race_levels),
race_2019 = factor(race_2019, levels = race_levels)
)
# --- Create transition table ---
tab_race <- table(
lca_pcp_merged_combine$race_2009,
lca_pcp_merged_combine$race_2019
)
# --- Add row and column totals ---
tab_race_with_margins <- addmargins(tab_race)
# --- Convert to data frame and label totals ---
tab_race_df <- as.data.frame.matrix(tab_race_with_margins) %>%
rownames_to_column(var = "2009 Race")
# Rename total column
names(tab_race_df)[ncol(tab_race_df)] <- "2019 Total"
# Rename total row
tab_race_df$`2009 Race` <- ifelse(
tab_race_df$`2009 Race` == "Sum",
"2009 Total",
tab_race_df$`2009 Race`
)
# --- Write to CSV ---
write.csv(
tab_race_df,
file = "race_transition_table_2009_2019.csv",
row.names = FALSE
)
class_labels <- c(
"1" = "Class 1 – Rural PCPs",
"2" = "Class 2 – Ob-gyns",
"3" = "Class 3 – Urban ambulatory care PCPs",
"4" = "Class 4 – Urban non-ambulatory care PCPs"
)
# --- Restrict to individuals observed in both years ---
lca_class_combine <- lca_descript %>%
filter(!is.na(class_09_ml), !is.na(class_19_ml)) %>%
mutate(
class_09_label = factor(
as.character(class_09_ml),
levels = names(class_labels),
labels = class_labels
),
class_19_label = factor(
as.character(class_19_ml),
levels = names(class_labels),
labels = class_labels
)
)
# --- Create transition table ---
tab_class <- table(
lca_class_combine$class_09_label,
lca_class_combine$class_19_label
)
# --- Add row and column totals ---
tab_class_with_margins <- addmargins(tab_class)
# --- Convert to data frame and label totals ---
tab_class_df <- as.data.frame.matrix(tab_class_with_margins) %>%
rownames_to_column(var = "2009 Class")
names(tab_class_df)[ncol(tab_class_df)] <- "2019 Total"
tab_class_df$`2009 Class` <- ifelse(
tab_class_df$`2009 Class` == "Sum",
"2009 Total",
tab_class_df$`2009 Class`
)
# --- Write to CSV ---
write.csv(
tab_class_df,
file = "class_transition_table_2009_2019.csv",
row.names = FALSE
)
# --- Restrict to individuals observed in both years ---
lca_class_combine <- lca_descript %>%
filter(!is.na(class_09_ml), !is.na(class_19_ml)) %>%
mutate(
class_09_label = factor(
as.character(class_09_ml),
levels = names(class_labels),
labels = class_labels
),
class_19_label = factor(
as.character(class_19_ml),
levels = names(class_labels),
labels = class_labels
)
)
# --- Create transition table ---
tab_class <- table(
lca_class_combine$class_09_label,
lca_class_combine$class_19_label
)
# --- Add row and column totals ---
tab_class_with_margins <- addmargins(tab_class)
# --- Convert to data frame and label totals ---
tab_class_df <- as.data.frame.matrix(tab_class_with_margins) %>%
rownames_to_column(var = "2009 Class")
names(tab_class_df)[ncol(tab_class_df)] <- "2019 Total"
tab_class_df$`2009 Class` <- ifelse(
tab_class_df$`2009 Class` == "Sum",
"2009 Total",
tab_class_df$`2009 Class`
)
# --- Write to CSV ---
write.csv(
tab_class_df,
file = "class_transition_table_2009_2019.csv",
row.names = FALSE
)
# --- Prepare Sankey data ---
sankey_class <- lca_descript %>%
filter(!is.na(class_09_ml), !is.na(class_19_ml)) %>%
mutate(
class_09_label = factor(
as.character(class_09_ml),
levels = names(class_labels),
labels = class_labels
),
class_19_label = factor(
as.character(class_19_ml),
levels = names(class_labels),
labels = class_labels
)
) %>%
count(class_09_label, class_19_label, name = "n")
# --- Sankey plot ---
p_class <- suppressWarnings(
ggplot(
sankey_class,
aes(
axis1 = class_09_label,
axis2 = class_19_label,
y     = n
)
) +
geom_alluvium(
aes(fill = class_09_label),
width = 1/12,
alpha = 0.85
) +
geom_stratum(
width = 1/12,
fill  = "grey90",
color = "black"
) +
geom_text(
stat = "stratum",
aes(label = str_wrap(after_stat(stratum), 30)),
size = 3.2,
lineheight = 0.9,
color = "black"
) +
scale_x_discrete(
limits = c("2009 Class", "2019 Class"),
expand = c(0.15, 0.25)
) +
coord_cartesian(clip = "off") +
labs(
title    = "Latent Class Transitions from 2009 to 2019",
subtitle = "Restricted to physicians observed in both years",
y        = "Number of Physicians",
x        = NULL,
fill     = "2009 Class"
) +
theme_minimal() +
theme(
legend.position     = "right",
panel.grid.major.x = element_blank(),
panel.grid.minor   = element_blank(),
plot.margin        = margin(t = 10, r = 90, b = 10, l = 90)
)
)
# --- Save to PNG ---
ggsave(
filename = "class_sankey_2009_2019.png",
plot     = p_class,
width    = 11,
height   = 6.5,
dpi      = 300,
bg       = "white"
)
