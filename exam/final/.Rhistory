"TG (mg/dl)"      = "TRIG",
"HOMA-IR"         = "HOMA_IR",
"SBP (mmHg)"      = "MCORRSYS",
"DBP (mmHg)"      = "MCORRDIA",
"FBG (mg/dL)"     = "MFBG",
"ACR (log mg/g)"  = "ACR"
)
# ==============================================================================
# 2. HELPER FUNCTION: Run both models for a single variable
# ==============================================================================
analyze_variable <- function(label, col_name, data) {
# Check if column exists
if(!col_name %in% names(data)) return(NULL)
# Filter clean data for this variable
df_clean <- data %>%
filter(!is.na(.data[[col_name]]),
!is.na(discordance),
!is.na(eGFR_diff))
if(nrow(df_clean) < 10) return(NULL)
# --- LOG TRANSFORMATION for ACR ---
if(col_name == "ACR") {
df_clean[[col_name]] <- log1p(df_clean[[col_name]])
}
# --- PART A: DISCORDANT vs CONCORDANT ---
# Model: Variable ~ discordance (0 = Concordant [ref], 1 = Discordant)
# Answers: "Is this variable significantly different in discordant vs concordant?"
model_disc <- lm(as.formula(paste(col_name, "~ factor(discordance)")), data = df_clean)
res_disc   <- tidy(model_disc, conf.int = TRUE)
disc_row <- res_disc %>% filter(term == "factor(discordance)1")
stats_disc <- if(nrow(disc_row) > 0) {
sprintf("%.2f (%.2f, %.2f)",
disc_row$estimate,
disc_row$conf.low,
disc_row$conf.high)
} else "-"
p_disc <- if(nrow(disc_row) > 0) {
format.pval(disc_row$p.value, eps = 0.001, digits = 3)
} else "-"
# --- PART B: PER 1 SD ANALYSIS ---
# Model: eGFR_diff ~ scale(Variable)
# Answers: "How does eGFR difference change per 1 SD increase in this variable?"
model_sd <- lm(eGFR_diff ~ scale(df_clean[[col_name]]), data = df_clean)
res_sd   <- tidy(model_sd, conf.int = TRUE)
sd_row <- res_sd %>% filter(term != "(Intercept)")
stats_sd <- if(nrow(sd_row) > 0) {
sprintf("%.2f (%.2f, %.2f)",
sd_row$estimate,
sd_row$conf.low,
sd_row$conf.high)
} else "-"
p_sd <- if(nrow(sd_row) > 0) {
format.pval(sd_row$p.value, eps = 0.001, digits = 3)
} else "-"
# --- COMBINE INTO ONE ROW ---
tibble(
Variable                          = label,
`Discordant vs Concordant Beta (95% CI)` = stats_disc,
`p-value`                         = p_disc,
`Per 1 SD Beta (95% CI)`          = stats_sd,
`SD p-value`                      = p_sd
)
}
# ==============================================================================
# 3. RUN LOOP
# ==============================================================================
results_table4 <- map2_dfr(names(var_map), var_map,
~ analyze_variable(.x, .y, paired))
# ==============================================================================
# 4. VIEW
# ==============================================================================
print(results_table4)
# ==== Packages ====
library(dplyr)
library(mgcv)
library(broom)
library(purrr)
library(tibble)
library(stringr)
# ==== Data ====
df <- cchc_3
# ==== Build outcome: eGFRdii = eGFRCr − eGFRcys ====
stopifnot(all(c("EGFR_CYS","CKD_EPI_GFR_CALC") %in% names(df)))
dat <- df %>%
mutate(
EGFR_CYS         = suppressWarnings(as.numeric(EGFR_CYS)),
CKD_EPI_GFR_CALC = suppressWarnings(as.numeric(CKD_EPI_GFR_CALC)),
eGFRdii           = CKD_EPI_GFR_CALC - EGFR_CYS
) %>%
filter(!is.na(eGFRdii)) %>%
## Select only 1st observation for RRID ##
arrange(RRID, AGE_AT_VISIT) %>%
group_by(RRID) %>%
slice(1) %>%
ungroup()
# ==== Clean/derive predictors ====
# 1. HbA1c trim (4–14)
if ("GHB" %in% names(dat)) {
dat <- dat %>%
mutate(GHB = suppressWarnings(as.numeric(GHB)),
GHB = ifelse(GHB < 4 | GHB > 14, NA_real_, GHB))
}
# 2. Gender (Female as reference)
if ("GENDER" %in% names(dat)) {
dat <- dat %>%
mutate(GENDER = suppressWarnings(as.numeric(GENDER)),
gender = case_when(
GENDER %in% c(1,2) ~ factor(GENDER, levels = c(2,1), labels = c("Female","Male")),
TRUE ~ NA
))
}
# 3. Diabetes status
if ("ADA2010_CAT" %in% names(dat)) {
dat <- dat %>%
mutate(dm = factor(ADA2010_CAT == 3, levels = c(FALSE, TRUE), labels = c("No DM","DM")))
}
# 4. Log-transform ACR (Critical for skewed distribution)
# We use log(x + 0.001) to handle potential zeros safely
if ("ACR" %in% names(dat)) {
dat <- dat %>%
mutate(
ACR = suppressWarnings(as.numeric(ACR)),
log_acr = log(ACR + 0.001)
)
}
# 5. Continuous predictors map (including LV Mass and log_acr)
pred_map_cont <- c(
age      = "AGE_AT_VISIT",
bmi      = "BMI1",
waist    = "WAIST",
hba1c    = "GHB",
hdl      = "HDLC",
tg       = "TRIG",
sbp      = "MCORRSYS",
dbp      = "MCORRDIA",
fbg      = "MFBG",
homa     = "HOMAIR",
log_acr  = "log_acr"
)
# Keep only columns that exist in the dataframe
pred_map_cont <- pred_map_cont[pred_map_cont %in% names(dat)]
# 6. Coerce to numeric and generate Z-scores
# Note: Z-scores are calculated AFTER the log transformation of ACR
for (nm in pred_map_cont) dat[[nm]] <- suppressWarnings(as.numeric(dat[[nm]]))
z_names <- setNames(paste0(names(pred_map_cont), "_z"), names(pred_map_cont))
for (k in names(pred_map_cont)) {
dat[[z_names[[k]]]] <- as.numeric(scale(dat[[pred_map_cont[[k]]]]))
}
# ==== Unadjusted model helpers ====
# 1) GAM for continuous predictors
fit_unadj_cont <- function(pred_key, k_basis = 5) {
pred_z <- z_names[[pred_key]]
if (!pred_z %in% names(dat)) return(NULL)
fm <- as.formula(paste0("eGFRdii ~ s(", pred_z, ", k=", k_basis, ")"))
m  <- gam(fm, data = dat, method = "REML", na.action = na.omit)
sm <- summary(m)
s_tab <- sm$s.table
rown  <- rownames(s_tab)[stringr::str_detect(rownames(s_tab), paste0("\\b", pred_z, "\\b"))][1]
tibble(
predictor = pred_key,
type      = "smooth (unadjusted)",
edf       = round(s_tab[rown, "edf"], 2),
F_stat    = round(s_tab[rown, "F"], 2),
p_value   = signif(s_tab[rown, "p-value"], 3),
n         = sm$n
)
}
# 2) LM for binary predictors
fit_unadj_bin <- function(var_name, label) {
if (!var_name %in% names(dat)) return(NULL)
if (nlevels(na.omit(dat[[var_name]])) < 2) return(NULL)
m  <- lm(reformulate(var_name, response = "eGFRdii"), data = dat)
tt <- tidy(m, conf.int = TRUE)
coef_row <- tt %>% filter(term != "(Intercept)") %>% slice(1)
tibble(
predictor = label,
type      = "binary (unadjusted)",
estimate  = round(coef_row$estimate, 2),
CI_95     = sprintf("%.2f, %.2f", round(coef_row$conf.low, 2), round(coef_row$conf.high, 2)),
p_value   = signif(coef_row$p.value, 3),
n         = nobs(m)
)
}
# ==== Run all unadjusted models ====
res_cont <- map_dfr(names(pred_map_cont), fit_unadj_cont) %>%
arrange(p_value)
res_bin <- bind_rows(
if ("gender" %in% names(dat)) fit_unadj_bin("gender", "Gender (Male vs Female)"),
if ("dm" %in% names(dat))     fit_unadj_bin("dm",     "Diabetes (DM vs No DM)")
)
# ==== Print results ====
cat("\nUNADJUSTED NONLINEAR MODELS (eGFRdii ~ s(predictor))\n")
print(res_cont)
if (!is.null(res_bin) && nrow(res_bin) > 0) {
cat("\nUNADJUSTED BINARY MODELS (mean difference in eGFRdii)\n")
print(res_bin)
}
# ==== Adjusted model helper ====
# We adjust for age (as a smooth) and gender (as a factor)
fit_adj_cont <- function(pred_key, k_basis = 5) {
pred_z <- z_names[[pred_key]]
# Skip if the predictor is age itself (can't adjust for itself)
# or if required columns are missing
if (pred_key == "age" || !pred_z %in% names(dat) ||
!"age_z" %in% names(dat) || !"gender" %in% names(dat)) return(NULL)
# Formula: outcome ~ s(predictor) + s(age) + gender
fm <- as.formula(paste0("eGFRdii ~ s(", pred_z, ", k=", k_basis, ") + s(age_z, k=5) + gender"))
m  <- gam(fm, data = dat, method = "REML", na.action = na.omit)
sm <- summary(m)
s_tab <- sm$s.table
# Find the row specifically for our predictor of interest
rown  <- rownames(s_tab)[stringr::str_detect(rownames(s_tab), paste0("\\b", pred_z, "\\b"))][1]
tibble(
predictor = pred_key,
type      = "smooth (Age/Gender Adjusted)",
edf       = round(s_tab[rown, "edf"], 2),
F_stat    = round(s_tab[rown, "F"], 2),
p_value   = signif(s_tab[rown, "p-value"], 3),
n         = sm$n
)
}
# 2) LM for binary predictors (e.g., Diabetes) adjusted for Age/Gender
fit_adj_bin <- function(var_name, label) {
if (!var_name %in% names(dat) || var_name %in% c("gender")) return(NULL)
# Formula: outcome ~ predictor + age_z + gender
fm <- as.formula(paste0("eGFRdii ~ ", var_name, " + age_z + gender"))
m  <- lm(fm, data = dat)
tt <- tidy(m, conf.int = TRUE)
coef_row <- tt %>% filter(term == paste0(var_name, "DM")) %>% slice(1)
if(nrow(coef_row) == 0) coef_row <- tt %>% filter(term != "(Intercept)" & !term %in% c("age_z", "genderMale")) %>% slice(1)
tibble(
predictor = label,
type      = "binary (Age/Gender Adjusted)",
estimate  = round(coef_row$estimate, 2),
CI_95     = sprintf("%.2f, %.2f", round(coef_row$conf.low, 2), round(coef_row$conf.high, 2)),
p_value   = signif(coef_row$p.value, 3),
n         = nobs(m)
)
}
# ==== Run all adjusted models ====
# We exclude 'age' from the list because it's a covariate
continuous_to_test <- names(pred_map_cont)[names(pred_map_cont) != "age"]
res_cont_adj <- map_dfr(continuous_to_test, fit_adj_cont) %>%
arrange(p_value)
res_bin_adj <- bind_rows(
if ("dm" %in% names(dat)) fit_adj_bin("dm", "Diabetes (DM vs No DM)")
)
# ==== Print results ====
cat("\nADJUSTED NONLINEAR MODELS (eGFRdii ~ s(pred) + s(age) + gender)\n")
print(res_cont_adj)
if (!is.null(res_bin_adj) && nrow(res_bin_adj) > 0) {
cat("\nADJUSTED BINARY MODELS (Age/Gender Adjusted)\n")
print(res_bin_adj)
}
# ==== Packages ====
library(dplyr)
library(tidyr)
library(broom)
library(knitr)
library(kableExtra)
library(stringr)
# ==== 0) Data prep ====
df <- renal %>%
mutate(
# 1=Male, 2=Female  → Male is reference so table shows "GENDER: Female"
GENDER = factor(GENDER, levels = c(1, 2), labels = c("Male", "Female")),
# Adjust labels if your coding differs
ADA2010_CAT = factor(ADA2010_CAT,
levels = c(1, 2, 3),
labels = c("Non-DM", "Pre-DM", "DM"))
)
# Variables to report (rows)
variables <- c("AGE_AT_VISIT","GENDER","BMI1","ADA2010_CAT",
"GHB","ACR","MCORRSYS","HOMA_IR","AGE_AT_VISIT:ADA2010_CAT")
# Outcome
outcome   <- "CKD_EPI_GFR_CALC"
# Pretty p-value formatting
fmt_p <- function(p) {
ifelse(p < 1e-4, formatC(p, format = "e", digits = 2),
ifelse(p < 0.001, sprintf("%.4f", p), sprintf("%.3f", p)))
}
# Make readable, unique labels for factor and interaction terms
make_level_label <- function(variable, term, dat) {
if (variable == "AGE_AT_VISIT:ADA2010_CAT") {
# e.g., term "AGE_AT_VISIT:ADA2010_CATPre-DM" -> "Age × ADA2010_CAT: Pre-DM vs Non-DM"
lev <- sub("^AGE_AT_VISIT:ADA2010_CAT", "", term)
lev <- gsub("^:", "", lev)
return(paste0("Age × ADA2010_CAT: ", lev, " vs Non-DM"))
} else if (variable %in% names(dat) && is.factor(dat[[variable]])) {
# e.g., "ADA2010_CATDM" -> "ADA2010_CAT: DM vs Non-DM"
base <- sub(paste0("^", variable), "", term)
base <- gsub("^", "", base)
base <- gsub("^", "", base)
base <- gsub("^", "", base)
base <- gsub("^", "", base)  # harmless; keeps tidy if term already clean
base <- gsub("^", "", base)
base <- gsub("^", "", base)
base <- gsub("^", "", base)
base <- sub(paste0("^", variable), "", term)
base <- gsub("^", "", base)
base <- gsub("^", "", base)
base <- gsub("^", "", base)
base <- str_replace(term, paste0("^", variable), "")
base <- str_replace(base, "^", "")
base <- str_replace(base, ":", "")
lev  <- str_trim(base)
# If lev is empty, it's the reference; we don't show ref rows here
return(paste0(variable, ": ", lev, " vs ", levels(dat[[variable]])[1]))
} else {
return(variable)
}
}
# ==== 1) Run models for one variable ====
run_models <- function(dat, variable, outcome) {
models <- list(
"Not Adjusted" = paste(outcome, "~", variable),
"Adjusted for Age, Gender" =
paste(outcome, "~", variable, "+ AGE_AT_VISIT + GENDER"),
"Adjusted for Age, Gender, BMI, ADA2010_CAT" =
paste(outcome, "~", variable, "+ AGE_AT_VISIT + GENDER + BMI1 + ADA2010_CAT")
)
res <- lapply(names(models), function(mname) {
fit <- lm(as.formula(models[[mname]]), data = dat)
T   <- tidy(fit, conf.int = TRUE)
# Keep only rows for this variable (handles factor levels and interaction)
if (variable == "AGE_AT_VISIT:ADA2010_CAT") {
T <- T %>% filter(grepl("^AGE_AT_VISIT:ADA2010_CAT", term))
Level <- vapply(T$term, make_level_label, character(1), variable = variable, dat = dat)
} else if (variable %in% names(dat) && is.factor(dat[[variable]])) {
T <- T %>% filter(grepl(paste0("^", variable), term))
Level <- vapply(T$term, make_level_label, character(1), variable = variable, dat = dat)
} else {
T <- T %>% filter(term == variable)
Level <- variable
}
tibble(
Model   = mname,
Level   = Level,
Coeff   = paste0(round(T$estimate, 3), " (",
round(T$conf.low, 3), ", ", round(T$conf.high, 3), ")"),
P_value = fmt_p(T$p.value)
)
}) %>% bind_rows()
res %>% mutate(Variable = variable)
}
# ==== 2) Run for all variables ====
final_results <- lapply(variables, function(v) run_models(df, v, outcome)) %>%
bind_rows() %>%
mutate(Outcome = outcome, .before = 1) %>%
distinct(Outcome, Variable, Level, Model, Coeff, P_value, .keep_all = TRUE)  # ensure uniqueness
# Optional: check duplicates (should return 0 rows)
# final_results %>%
#   dplyr::summarise(n = dplyr::n(), .by = c(Outcome, Variable, Level, Model)) %>%
#   dplyr::filter(n > 1L)
# ==== 3) Pivot wider: Coeff and p-value per model ====
formatted_table <- final_results %>%
pivot_wider(
id_cols = c(Outcome, Variable, Level),
names_from = Model,
values_from = c(Coeff, P_value)
)
# ==== 4) Display ====
formatted_table %>%
kable(
caption = "Unadjusted and Adjusted Associations with eGFRcr (CKD_EPI_GFR_CALC)",
booktabs = TRUE
) %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"),
full_width = FALSE) %>%
add_header_above(c(" " = 3,
"Not Adjusted" = 2,
"Adj. Age, Gender" = 2,
"Adj. Age, Gender, BMI, ADA2010_CAT" = 2))
