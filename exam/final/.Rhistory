rm(list = ls())
#Reading in libraries
library(haven)
library(tidyverse)
library(broom)
library(tidymodels)
#Setting directories
prot_dir  <- "C:\\Users\\aghoward\\OneDrive - University of North Carolina at Chapel Hill\\UNC\\SOB\\Data\\Proteomics\\Batch1_2_3"
pheno_dir <- "C:\\Users\\aghoward\\OneDrive - University of North Carolina at Chapel Hill\\UNC\\SOB\\Data\\Phenotype"
cchc_3 <- read_sas(file.path(pheno_dir, "\\Oct2025\\cchc.sas7bdat"))
library(kableExtra)
install.packages("threeparttable")
